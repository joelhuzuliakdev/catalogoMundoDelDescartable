---
import { companyInfo } from '../data/products.js';
---

<header
    id="main-header"
    class="bg-gradient-to-r from-slate-800 to-slate-700 text-white shadow-lg no-print sticky top-0 z-50 transition-transform duration-300 will-change-transform"
    >
    <div class="container mx-auto px-4 py-3">
        <div class="flex items-center justify-between gap-3">

        <!-- BLOQUE IZQUIERDO: LOGO + TITULO -->
        <div class="flex items-center gap-3 min-w-0">
            <div class="w-10 h-10 shrink-0 rounded-full overflow-hidden bg-white flex items-center justify-center">
                <img
                    src="/mundoLogo.webp"
                    alt="Logo empresa"
                    class="w-full h-full object-contain"
                />
            </div>
            <div class="min-w-0">
                <h1 class="text-base md:text-3xl font-bold tracking-tight leading-tight">
                    {companyInfo.name}
                </h1>
                <p class="text-slate-300 text-xs mt-0.5">
                    Catálogo de Productos
                </p>
            </div>
        </div>

        <!-- BLOQUE DERECHO: TELÉFONO + BOTÓN CATEGORÍAS -->
        <div class="flex items-center gap-3 shrink-0">
            <div class="hidden md:flex items-center gap-2 text-sm text-slate-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <span>{companyInfo.phone}</span>
            </div>

            <!-- BOTÓN CATEGORÍAS -->
            <button
                id="toggle-categories"
                class="flex items-center gap-1.5 px-3 py-2 rounded-lg bg-white/10 hover:bg-white/20 transition-colors text-sm font-medium text-white border border-white/20 whitespace-nowrap"
                aria-expanded="false"
            >
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
                <span>Categorías</span>
                <svg id="chevron-icon" class="w-3 h-3 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
        </div>

        </div>
    </div>
</header>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let lastScroll = 0;
        const header = document.getElementById('main-header');
        const toggleBtn = document.getElementById('toggle-categories');
        const categoryNav = document.getElementById('category-nav');
        const chevron = document.getElementById('chevron-icon');

        // Toggle categorías desde el header
        toggleBtn?.addEventListener('click', () => {
            const isHidden = categoryNav?.classList.contains('nav-collapsed');

            if (isHidden) {
                categoryNav?.classList.remove('nav-collapsed');
                chevron?.classList.add('rotate-180');
                toggleBtn?.setAttribute('aria-expanded', 'true');
            } else {
                categoryNav?.classList.add('nav-collapsed');
                chevron?.classList.remove('rotate-180');
                toggleBtn?.setAttribute('aria-expanded', 'false');
            }
        });

        // Scroll hide/show
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;

            if (currentScroll <= 0) {
                header?.classList.remove('-translate-y-full');
                return;
            }

            if (currentScroll > lastScroll && currentScroll > 100) {
                header?.classList.add('-translate-y-full');
            } else {
                header?.classList.remove('-translate-y-full');
            }

            lastScroll = currentScroll;
        });
    });
</script>